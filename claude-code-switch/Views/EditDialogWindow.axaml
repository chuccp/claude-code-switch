<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:ConsoleApp1.ViewModels"
        xmlns:converters="using:ConsoleApp1.Converters"
        x:Class="ConsoleApp1.Views.EditDialogWindow"
        x:DataType="vm:EditDialogViewModel"
        Title="{Binding Title}"
        Width="900" Height="700"
        MinWidth="700" MinHeight="550"
        WindowStartupLocation="CenterOwner"
        CanResize="True"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaChromeHints="NoChrome"
        ExtendClientAreaTitleBarHeightHint="-1"
        SystemDecorations="None">

    <Window.Resources>
        <converters:StringIsNotNullOrEmptyConverter x:Key="StringIsNotNullOrEmpty"/>
    </Window.Resources>

    <Grid RowDefinitions="Auto,*,Auto">
        <!-- 自定义标题栏 -->
        <Border Grid.Row="0"
                Classes="titlebar"
                Padding="16,8"
                x:Name="TitleBar"
                PointerPressed="OnTitleBarPointerPressed">
            <Grid>
                <TextBlock Text="{Binding Title}"
                          FontSize="14"
                          FontWeight="SemiBold"
                          VerticalAlignment="Center"
                          Foreground="{DynamicResource TextPrimaryBrush}"/>

                <!-- 关闭按钮 -->
                <Button x:Name="CloseButton"
                        Width="40" Height="32"
                       HorizontalAlignment="Right"
                       Background="Transparent"
                       CornerRadius="0"
                       Margin="0,0,0,0"
                       Click="OnCloseClick"
                       BorderThickness="0">
                    <TextBlock Text="✕" Padding="0" FontSize="14" Foreground="{DynamicResource TextSecondaryBrush}"/>
                </Button>
            </Grid>
        </Border>

        <!-- 内容区域：左右分栏 -->
        <Grid Grid.Row="1" ColumnDefinitions="*,*" Margin="24,0,24,16">
            <!-- 左侧：表单编辑 -->
            <ScrollViewer Grid.Column="0">
                <StackPanel Spacing="16" Margin="0,0,12,0">
                    <TextBlock x:Name="FormEditLabel" Text="表单编辑" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="14" FontWeight="SemiBold"/>

                    <!-- 配置名称 -->
                    <StackPanel Spacing="6">
                        <TextBlock x:Name="ConfigNameLabel" Text="配置名称" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="13"/>
                        <TextBox x:Name="NameTextBox" Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                Watermark="请输入配置名称"/>
                    </StackPanel>

                    <!-- API 配置 -->
                    <StackPanel Spacing="6">
                        <TextBlock x:Name="ApiConfigLabel" Text="API 配置" Foreground="{DynamicResource AccentBrush}" FontSize="14" FontWeight="SemiBold"/>

                        <StackPanel Spacing="6">
                            <TextBlock Text="ANTHROPIC_AUTH_TOKEN" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12"/>
                            <TextBox Text="{Binding AuthToken, UpdateSourceTrigger=PropertyChanged}"
                                    Watermark="sk-..."/>
                        </StackPanel>

                        <StackPanel Spacing="6">
                            <TextBlock Text="ANTHROPIC_BASE_URL" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12"/>
                            <TextBox Text="{Binding BaseUrl, UpdateSourceTrigger=PropertyChanged}"
                                    Watermark="https://api.anthropic.com"/>
                        </StackPanel>

                        <StackPanel Spacing="6">
                            <TextBlock Text="ANTHROPIC_MODEL" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12"/>
                            <TextBox Text="{Binding Model, UpdateSourceTrigger=PropertyChanged}"
                                    Watermark="claude-sonnet-4-20250514"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>

            <!-- 右侧：JSON 编辑 -->
            <ScrollViewer Grid.Column="1">
                <StackPanel Spacing="8" Margin="12,0,0,0">
                    <TextBlock x:Name="JsonConfigLabel" Text="JSON 配置" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="14" FontWeight="SemiBold"/>
                    <TextBox Text="{Binding JsonText, UpdateSourceTrigger=PropertyChanged}"
                            AcceptsReturn="True"
                            TextWrapping="Wrap"
                            x:Name="JsonWatermark"
                            Watermark="在此输入 JSON 配置，修改将自动同步到左侧表单..."
                            FontFamily="Consolas,Courier New,monospace"
                            FontSize="12"
                            MinHeight="400"/>
                    
                    <!-- JSON 错误提示 -->
                    <Border IsVisible="{Binding JsonError, Converter={StaticResource StringIsNotNullOrEmpty}}"
                           Background="{DynamicResource ErrorBackgroundBrush}"
                           CornerRadius="6"
                           Padding="12,8">
                        <TextBlock Text="{Binding JsonError}"
                                  Foreground="{DynamicResource ErrorBrush}"
                                  FontSize="12"/>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!-- 按钮 -->
        <Border Grid.Row="2"
               Classes="statusbar"
               Padding="16,12">
            <StackPanel Orientation="Horizontal"
                       Spacing="20"
                       HorizontalAlignment="Right">
                <Button Content="{Binding ConfirmText}"
                       Command="{Binding SaveCommand}"
                       IsEnabled="{Binding CanSave}"
                       Classes="accent"
                       MinWidth="100" MinHeight="36"/>
                <Button Content="取消"
                       Command="{Binding CancelCommand}"
                       MinWidth="100" MinHeight="36"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
